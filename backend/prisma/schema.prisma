generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- PORTAL SPECIFIC MODELS ---

model AdminUser {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  name         String?
  role                 String   @default("SUPER_ADMIN")
  recoveryKey          String?  // Master recovery key generated on setup
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  mfaEnabled           Boolean  @default(false)
  mfaSetupPending      Boolean  @default(false)
  mfaTempSecret        String?
  mfaRecoveryCodes     String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model GlobalParameter {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  type      String   @default("STRING")
  group     String?
  updatedAt DateTime @updatedAt
}

model BranchBackup {
  id        String   @id @default(cuid())
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id])
  filename  String
  size      Int
  url       String
  createdAt DateTime @default(now())
}

model Release {
  id          String   @id @default(cuid())
  version     String   @unique
  description String?
  url         String
  severity    Int      @default(5)
  isCurrent   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model CentralLog {
  id        String   @id @default(cuid())
  level     String   @default("INFO")
  message   String
  source    String?
  context   String?
  createdAt DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  userName    String?
  entityType  String
  entityId    String?
  action      String
  details     String?  // JSON stringified details
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
}

model AdminItemType {
  id               String   @id @default(cuid())
  code             String   @unique
  name             String
  category         String?
  requiresSerial   Boolean  @default(true)
  description      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  assets           AdminAsset[]
  stocks           AdminStock[]
}

model AdminAsset {
  id               String   @id @default(cuid())
  serialNumber     String   @unique
  itemTypeCode     String
  itemType         AdminItemType @relation(fields: [itemTypeCode], references: [code])
  status           String   @default("AVAILABLE") // AVAILABLE, TRANSFERRED, LOST, MAINTENANCE
  cartonId         String?
  carton           AdminCarton? @relation(fields: [cartonId], references: [id])
  currentBranchId  String?  // If transferred to a branch
  lastAction       String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  history          AdminAssetHistory[]
}

model AdminCarton {
  id               String   @id @default(cuid())
  cartonCode       String   @unique
  description      String?
  status           String   @default("AVAILABLE")
  assets           AdminAsset[]
  createdAt        DateTime @default(now())
}

model AdminAssetHistory {
  id               String   @id @default(cuid())
  assetId          String
  asset            AdminAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  action           String
  fromBranchId     String?
  toBranchId       String?
  performedBy      String?
  details          String?
  createdAt        DateTime @default(now())
}

model AdminStock {
  id               String   @id @default(cuid())
  itemTypeCode     String
  itemType         AdminItemType @relation(fields: [itemTypeCode], references: [code])
  branchId         String
  quantity         Int      @default(0)
  lastUpdated      DateTime @updatedAt
  
  @@unique([itemTypeCode, branchId])
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model SyncQueue {
  id         String   @id @default(cuid())
  branchId   String
  entityType String   // e.g., "USER", "SPARE_PART", "PARAMETER"
  action     String   // e.g., "CREATE", "UPDATE", "DELETE"
  payload    String   // JSON stringified payload
  status     String   @default("PENDING") // PENDING, SYNCED, ERROR
  error      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
}

model MachineParameter {
  id           String @id @default(cuid())
  prefix       String @unique
  model        String
  manufacturer String
}

model MasterSparePart {
  id               String   @id @default(cuid())
  partNumber       String?  @unique
  name             String
  description      String?
  compatibleModels String?
  defaultCost      Float    @default(0)
  isConsumable     Boolean  @default(false)
  category         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  priceLogs        SparePartPriceLog[]
}

model SparePartPriceLog {
  id        String   @id @default(cuid())
  partId    String
  part      MasterSparePart @relation(fields: [partId], references: [id], onDelete: Cascade)
  oldCost   Float
  newCost   Float
  changedBy String?
  changedAt DateTime @default(now())
}

// --- ENTERPRISE MODELS (Mirroring main system) ---

model User {
  id                 String            @id @default(cuid())
  uid                String?           @unique
  username           String?           @unique
  email              String?           @unique
  displayName        String?
  role               String?           @default("CS_AGENT")
  password           String?
  theme              String?           @default("light")
  fontFamily         String?           @default("sans-serif")
  fontSize           String?           @default("medium")
  highlightEffect    Boolean           @default(true)
  notificationSound  Boolean           @default(true)
  mobilePush         Boolean           @default(false)
  createdAt          DateTime          @default(now())
  branchId           String?
  passwordChangedAt  DateTime          @default(now())
  mustChangePassword Boolean           @default(false)
  lastLoginAt        DateTime?
  loginCount         Int               @default(0)
  mfaEnabled         Boolean           @default(false)
  mfaSecret          String?
  mfaRecoveryCodes   String?
  mfaSetupPending    Boolean           @default(false)
  mfaTempSecret      String?
  isActive              Boolean           @default(true)
  resetPasswordToken    String?
  resetPasswordExpires  DateTime?
  accountLockout        AccountLockout?
  passwordHistory    PasswordHistory[]
  refreshTokens      RefreshToken[]
  branch             Branch?           @relation(fields: [branchId], references: [id])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Branch {
  id                                              String                @id @default(cuid())
  code                                            String                @unique
  name                                            String
  address                                         String?
  type                                            String                @default("BRANCH")
  isActive                                        Boolean               @default(true)
  phone                                           String?
  authorizedHWID                                  String?
  parentBranchId                                  String?
  createdAt                                       DateTime              @default(now())
  parentBranch                                    Branch?               @relation("BranchHierarchy", fields: [parentBranchId], references: [id])
  childBranches                                   Branch[]              @relation("BranchHierarchy")
  customers                                       Customer[]
  installments                                    Installment[]
  inventory                                       InventoryItem[]
  machineMovementLogs                             MachineMovementLog[]
  machineSales                                    MachineSale[]
  requests                                        MaintenanceRequest[]
  notifications                                   Notification[]
  payments                                        Payment[]
  posMachines                                     PosMachine[]
  simCards                                        SimCard[]
  simMovementLogs                                 SimMovementLog[]
  stockMovements                                  StockMovement[]
  systemLogs                                      SystemLog[]
  sentTransfers                                   TransferOrder[]       @relation("SentTransfers")
  receivedTransfers                               TransferOrder[]       @relation("ReceivedTransfers")
  usedPartLogs                                    UsedPartLog[]
  users                                           User[]
  maintenanceApprovals                            MaintenanceApproval[]
  warehouseMachines                               WarehouseMachine[]
  warehouseSims                                   WarehouseSim[]
  
  // Portal specific additions
  url                                             String?
  apiKey                                          String?               @unique
  status                                          String                @default("OFFLINE")
  lastSeen                                        DateTime?
  version                                         String?
  backups                                         BranchBackup[]
  syncQueues                                      SyncQueue[]
}

model Customer {
  id              String               @id @default(cuid())
  bkcode          String               @unique
  client_name     String
  supply_office   String?
  operating_date  DateTime?
  address         String?
  contact_person  String?
  scanned_id_path String?
  national_id     String?
  dept            String?
  telephone_1     String?
  telephone_2     String?
  has_gates       Boolean?             @default(false)
  bk_type         String?
  notes           String?
  papers_date     DateTime?
  isSpecial       Boolean?             @default(false)
  clienttype      String?
  status          String?              @default("Active")
  branchId        String?
  branch          Branch?              @relation(fields: [branchId], references: [id])
  machineSales    MachineSale[]
  requests        MaintenanceRequest[]
  payments        Payment[]
  machines        PosMachine[]
  simCards        SimCard[]
  warehouseMachines WarehouseMachine[]
}

model SparePart {
  id               String          @id @default(cuid())
  partNumber       String?
  name             String
  description      String?
  compatibleModels String?
  defaultCost      Float           @default(0)
  isConsumable     Boolean?        @default(false)
  allowsMultiple   Boolean?        @default(false)
  inventoryItems   InventoryItem[]
}

model InventoryItem {
  id       String    @id @default(cuid())
  partId   String
  quantity Int       @default(0)
  minLevel Int       @default(0)
  location String?
  branchId String?
  branch   Branch?   @relation(fields: [branchId], references: [id])
  part     SparePart @relation(fields: [partId], references: [id])
}

model MaintenanceRequest {
  id                  String               @id @default(cuid())
  customerId          String
  posMachineId        String?
  customerName        String?
  customerBkcode      String?
  machineModel        String?
  machineManufacturer String?
  serialNumber        String?
  status              String               @default("Open")
  branchId            String?
  servicedByBranchId  String?
  technicianId        String?
  technician          String?
  type                String?
  description         String?
  createdBy           String?
  notes               String?
  complaint           String?
  actionTaken         String?
  createdAt           DateTime             @default(now())
  closingUserId       String?
  closingUserName     String?
  closingTimestamp    DateTime?
  usedParts           String?
  receiptNumber       String?
  totalCost           Float?               @default(0)
  branch              Branch?              @relation(fields: [branchId], references: [id])
  customer            Customer             @relation(fields: [customerId], references: [id])
  posMachine          PosMachine?          @relation(fields: [posMachineId], references: [id])
  payments            Payment[]
  stockMovements      StockMovement[]
  warehouseMachines   WarehouseMachine[]
  maintenanceApprovals MaintenanceApproval[]
}

model TransferOrder {
  id               String              @id @default(cuid())
  orderNumber      String              @unique
  waybillNumber    String?
  branchId         String?
  fromBranchId     String
  toBranchId       String
  status           String              @default("PENDING")
  type             String
  driverName       String?
  driverPhone      String?
  notes            String?
  createdBy        String?
  createdByName    String?
  createdByUserId  String?
  receivedByUserId String?
  receivedAt       DateTime?
  receivedBy       String?
  receivedByName   String?
  rejectionReason  String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  fromBranch       Branch              @relation("SentTransfers", fields: [fromBranchId], references: [id])
  toBranch         Branch              @relation("ReceivedTransfers", fields: [toBranchId], references: [id])
  items            TransferOrderItem[]
}

model TransferOrderItem {
  id              String        @id @default(cuid())
  transferOrderId String
  serialNumber    String?
  type            String?
  model           String?
  manufacturer    String?
  isReceived      Boolean       @default(false)
  receivedAt      DateTime?
  notes           String?
  transferOrder   TransferOrder @relation(fields: [transferOrderId], references: [id], onDelete: Cascade)
}

model UsedPartLog {
  id             String   @id @default(cuid())
  requestId      String
  customerId     String
  customerName   String?
  customerBkcode String?
  posMachineId   String?
  technician     String?
  closedByUserId String?
  closedAt       DateTime @default(now())
  parts          String
  receiptNumber  String?
  branchId       String?
  branch         Branch?  @relation(fields: [branchId], references: [id])
}

model StockMovement {
  id          String   @id @default(cuid())
  partId      String
  type        String
  quantity    Int
  reason      String?
  requestId   String?
  userId      String?
  performedBy String?
  branchId      String?
  isPaid        Boolean? @default(false)
  receiptNumber String?
  createdAt     DateTime @default(now())
  branch        Branch?            @relation(fields: [branchId], references: [id])
  request       MaintenanceRequest? @relation(fields: [requestId], references: [id])
}

model Payment {
  id            String    @id @default(cuid())
  customerId    String?
  customerName  String?
  requestId     String?
  amount        Float
  type          String?
  reason        String?
  paymentPlace  String?
  paymentMethod String?
  receiptNumber String?
  notes         String?
  userId        String?
  userName      String?
  branchId      String?
  createdAt     DateTime            @default(now())
  branch        Branch?             @relation(fields: [branchId], references: [id])
  customer      Customer?           @relation(fields: [customerId], references: [id])
  request       MaintenanceRequest? @relation(fields: [requestId], references: [id])
}

model MachineMovementLog {
  id           String   @id @default(cuid())
  machineId    String?
  serialNumber String
  action       String
  details      String?
  performedBy  String?
  branchId     String?
  createdAt    DateTime @default(now())
  Branch       Branch?  @relation(fields: [branchId], references: [id])
}

model SystemLog {
  id          String   @id @default(cuid())
  entityType  String
  entityId    String
  action      String
  details     String?
  performedBy String?
  userId      String?
  branchId    String?
  createdAt   DateTime @default(now())
  branch      Branch?  @relation(fields: [branchId], references: [id])
}

model PasswordHistory {
  id           String   @id @default(cuid())
  userId       String
  passwordHash String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model AccountLockout {
  id                String    @id @default(cuid())
  userId            String    @unique
  failedAttempts    Int       @default(0)
  lastFailedAttempt DateTime?
  lockedUntil       DateTime?
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lockedUntil])
}

model Installment {
  id            String      @id @default(cuid())
  saleId        String
  dueDate       DateTime
  amount        Float
  isPaid        Boolean     @default(false)
  paidAt        DateTime?
  description   String?
  paidAmount    Float?
  paymentPlace  String?
  receiptNumber String?
  branchId      String?
  branch        Branch?     @relation(fields: [branchId], references: [id])
  sale          MachineSale @relation(fields: [saleId], references: [id])
}

model MachineSale {
  id           String        @id @default(cuid())
  serialNumber String
  customerId   String
  saleDate     DateTime      @default(now())
  type         String
  totalPrice   Float
  paidAmount   Float
  status       String
  notes        String?
  branchId     String?
  installments Installment[]
  branch       Branch?       @relation(fields: [branchId], references: [id])
  customer     Customer      @relation(fields: [customerId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  branchId  String?
  link      String?
  type      String
  title     String
  message   String
  data      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  branch    Branch?  @relation(fields: [branchId], references: [id])
}

model PosMachine {
  id           String               @id @default(cuid())
  serialNumber String               @unique
  posId        String?
  model        String?
  manufacturer String?
  customerId   String?
  branchId     String?
  requests     MaintenanceRequest[]
  branch       Branch?              @relation(fields: [branchId], references: [id])
  customer     Customer?            @relation(fields: [customerId], references: [id])
}

model RolePermission {
  id             String   @id @default(cuid())
  role           String
  permissionType String
  permissionKey  String
  isAllowed      Boolean  @default(true)
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  @@unique([role, permissionType, permissionKey])
}

model SimCard {
  id           String    @id @default(cuid())
  serialNumber String    @unique
  type         String?
  networkType  String?
  customerId   String?
  branchId     String?
  branch       Branch?   @relation(fields: [branchId], references: [id])
  customer     Customer? @relation(fields: [customerId], references: [id])
}

model SimMovementLog {
  id           String   @id @default(cuid())
  simId        String
  serialNumber String
  action       String
  details      String?
  performedBy  String?
  branchId     String?
  createdAt    DateTime @default(now())
  Branch       Branch?  @relation(fields: [branchId], references: [id])
}

model WarehouseMachine {
  id                    String              @id @default(cuid())
  serialNumber          String              @unique
  model                 String?
  manufacturer          String?
  status                String              @default("NEW")
  resolution            String?
  notes                 String?
  complaint             String?
  importDate            DateTime            @default(now())
  updatedAt             DateTime            @updatedAt @default(now())
  originalOwnerId       String?
  branchId              String?
  requestId             String?
  customerId            String?
  customerName          String?
  customerBkcode        String?
  readyForPickup        Boolean             @default(false)
  branch                Branch?             @relation(fields: [branchId], references: [id])
  customer              Customer?           @relation(fields: [customerId], references: [id])
  maintenanceRequest    MaintenanceRequest? @relation(fields: [requestId], references: [id])
}

model WarehouseSim {
  id           String   @id @default(cuid())
  serialNumber String   @unique
  type         String?
  networkType  String?
  status       String   @default("NEW")
  notes        String?
  importDate   DateTime @default(now())
  updatedAt    DateTime            @updatedAt @default(now())
  branchId     String?
  branch       Branch?  @relation(fields: [branchId], references: [id])
}

model MaintenanceApproval {
  id              String             @id @default(cuid())
  requestId       String
  cost            Float
  parts           String?            // JSON string
  notes           String?
  status          String             @default("PENDING") // PENDING, APPROVED, REJECTED
  branchId        String?
  respondedAt     DateTime?
  respondedBy     String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  
  branch          Branch?            @relation(fields: [branchId], references: [id])
  request         MaintenanceRequest @relation(fields: [requestId], references: [id])
}

model ClientType {
  id          String   @id @default(cuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
